<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>title</key>
	<string>MatisuXCS</string>
	<key>items</key>
	<array>
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string></string>
			<key>footerText</key>
			<string></string>
		</dict>

		<!-- Network: DHCP -> Static IP -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>网络</string>
			<key>footerText</key>
			<string>开启后将当前 Wi-Fi/以太网获取到的 IP、子网、路由器锁定为手动静态配置；关闭即恢复自动 DHCP。</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>defaults</key>
			<string>com.82flex.trollvnc</string>
			<key>key</key>
			<string>StaticIPEnabled</string>
			<key>label</key>
			<string>锁定 DHCP 为静态 IP</string>
			<key>default</key>
			<false/>
		</dict>

		<!-- Logout Device -->
		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>注销设备</string>
		<key>action</key>
			<string>respringDevice:</string>
			<key>isDestructive</key>
			<true/>
		</dict>
		
		<!-- Reboot Device -->
		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>重启设备</string>
			<key>action</key>
			<string>restartDevice:</string>
			<key>isDestructive</key>
			<true/>
		</dict>

		<!-- Device Info -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>WebDAV 文件管理</string>
			<key>footerText</key>
			<string>设置 WebDAV 默认根目录，留空则为 /（访问所有目录）。修改后重启 MatisuXCS 服务生效。</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSEditTextCell</string>
			<key>label</key>
			<string>WebDAV 根目录</string>
			<key>id</key>
			<string>WebDAVRootPath</string>
			<key>key</key>
			<string>WebDAVRootPath</string>
			<key>defaults</key>
			<string>com.82flex.trollvnc</string>
			<key>placeholder</key>
			<string>/（默认，访问所有目录）</string>
			<key>keyboard</key>
			<string>URL</string>
		</dict>

		<!-- Device Info -->
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>设备信息</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSTitleValueCell</string>
			<key>label</key>
			<string>设备名称</string>
			<key>id</key>
			<string>DeviceName</string>
			<key>get</key>
			<string>deviceNameValue</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSTitleValueCell</string>
			<key>label</key>
			<string>系统版本</string>
			<key>id</key>
			<string>SystemVersion</string>
			<key>get</key>
			<string>systemVersionValue</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSTitleValueCell</string>
			<key>label</key>
			<string>设备型号</string>
			<key>id</key>
			<string>DeviceModel</string>
			<key>get</key>
			<string>deviceModelValue</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSTitleValueCell</string>
			<key>label</key>
			<string>存储空间</string>
			<key>id</key>
			<string>StorageSpace</string>
			<key>get</key>
			<string>storageSpaceValue</string>
		</dict>

	</array>
</dict>
</plist>
