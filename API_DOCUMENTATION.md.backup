        method: 'POST',
        headers: { 'Content-Type': 'text/plain; charset=utf-8' },
        body: content
    });
    return response.json();
}

// 璁剧疆鍓创鏉?(Base64)
async function setClipboard(text) {
    const encoded = btoa(unescape(encodeURIComponent(text)));
    const response = await fetch(`${API_BASE}/api/clipboard`, {
